<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E26B46"
    android:backgroundTint="#DB441C"
    android:orientation="vertical"
    app:barrierMargin="@dimen/cardview_compat_inset_shadow"
    tools:context=".MainActivity">


    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="426dp"
        android:layout_height="556dp"
        app:srcCompat="@drawable/orange_stuff" />


    <Button
        android:id="@+id/getStartedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="45dp"
        android:text="Get Started" />

    <TextView
        android:id="@+id/welcomeTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginLeft="30dp"
        android:fontFamily="@font/akaya_kanadaka"
        android:text="Welcome! Spark your social life!"
        android:textColor="#FFFFFF"
        android:textSize="25sp" />


</LinearLayout>